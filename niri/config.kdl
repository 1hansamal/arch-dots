
prefer-no-csd

screenshot-path "~/Pictures/Screenshots/scr_%Y-%m-%d_%H-%M-%S.png"

hotkey-overlay { skip-at-startup; }

layer-rule {
    match namespace="MacNotch"

    shadow { off; }

    geometry-corner-radius 0
    place-within-backdrop true

    background-effect {
        xray true
        blur true
        noise 0.05
        saturation 3
    }
}

overview {
    zoom 0.5
    backdrop-color "#000000"

    workspace-shadow { off; }
}

switch-events { lid-close { spawn "systemctl" "suspend"; }; }

include "startup.kdl"
include "input.kdl"
include "outputs.kdl"
include "windowrules.kdl"
include "animations.kdl"
include "layout.kdl"
include "binds.kdl"

environment {
    QT_QPA_PLATFORM "wayland"
    QT_QPA_PLATFORMTHEME "qt6ct"
}
cursor { xcursor-size 16; }

blur {
    passes     1     // Number of blur iterations (higher = stronger)
    offset     2     // Sample distance per pass
    noise      0.01  // Grain overlay to prevent color banding
    saturation 1     // Boost or desaturate colors behind the window
}
