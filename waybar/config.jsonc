{
  "output": ["LVDS-1", "HDMI-A-3"],

  "name": "MacNotch",

  "layer": "top",
  "position": "top",
  // "mode": "dock",

  // "start_hidden": false,
  // "passthrough": false,
  // "ipc": false,
  // "id": ,
  "reload_style_on_change": true,

  // "width": ,
  "height": 20,
  // "margin-<top|left|bottom|right>": ,
