    "wlr/taskbar",
    "custom/div",
    // "niri/window",
    "network",
    "bluetooth",
    "custom/div",
    "mpris",
    "pulseaudio#sink",
    "pulseaudio#source",
    "custom/div",
    "battery",
    "backlight",
    "memory",
    "idle_inhibitor",
    "custom/div",
    // "tray",
    "custom/usrname"
  ]
